@page
@model TeknoForce.Pages.Admin.Products.EditModel
@{
    ViewData["Title"] = "Ürün";
    Layout = "_Layout";
}

<div class="admin-card">
    <h3>Ürün</h3>
</div>

<form method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <!-- 1️⃣ GENEL BİLGİLER -->
    <div class="admin-card">
        <input type="hidden" asp-for="Product.ProductId" />

        <div class="card-header">
            <strong>Genel Bilgiler</strong>
        </div>

        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Marka</label>
                    <select class="form-select"
                            asp-for="Product.BrandId"
                            asp-items="Model.BrandList">
                        <option value="">Marka seç</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Kategori</label>
                    <select class="form-select"
                            asp-for="Product.CategoryId"
                            asp-items="Model.CategoryList">
                        <option value="">Kategori seç</option>
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Ürün Adı</label>
                <input asp-for="Product.Name" class="form-control" />
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">
                        Fiyat (KDV Hariç)
                    </label>
                    <input asp-for="Product.Price" type="number" class="form-control" />

                </div>

                <div class="col-md-4">
                    <label class="form-label">Stok</label>
                    <input asp-for="Product.Stock" type="number" class="form-control" />
                </div>

                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input asp-for="Product.IsActive" class="form-check-input" type="checkbox">
                        <label class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <br />

    <!-- 2️⃣ TEKNİK ÖZELLİKLER -->
    <div class="admin-card">
        <input type="hidden" asp-for="Specification.ProductId" />

        <div class="card-header">
            <strong>Teknik Özellikler</strong>
        </div>

        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-4 fw-semibold">MAXIMUM NOZUL</div>
                <div class="col-md-8">
                    <input asp-for="Specification.MaxNozzle" class="form-control" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-semibold">MOTOR GÜCÜ (HP)</div>
                <div class="col-md-8">
                    <input asp-for="Specification.MotorPowerHP" class="form-control" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-semibold">AĞIRLIK (KG)</div>
                <div class="col-md-8">
                    <input asp-for="Specification.WeightKg" type="number" class="form-control" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-semibold">SET İÇERİĞİ</div>
                <div class="col-md-8">
                    <textarea asp-for="Specification.SetContent" class="form-control"></textarea>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-semibold">KULLANIM ALANLARI</div>
                <div class="col-md-8">
                    <textarea asp-for="Specification.UsageAreas" class="form-control"></textarea>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-semibold">KULLANILABİLİR MALZEMELER</div>
                <div class="col-md-8">
                    <textarea asp-for="Specification.UsableMaterials" class="form-control"></textarea>
                </div>
            </div>
        </div>
    </div>

    <br />

    <!-- 3️⃣ MEDYA (GÖRSEL + VİDEO) -->
    <div class="admin-card">
        <div class="card-header">
            <strong>Medya (Görsel + Video)</strong>
        </div>

        <div class="card-body">

            <div class="mb-3">
                <label class="form-label fw-semibold">Medya Yükle</label>
                <input asp-for="MediaFiles"
                       type="file"
                       multiple
                       class="form-control"
                       accept="image/*,video/mp4" />
                <small class="text-muted">
                    Görsel ve mp4 video yükleyebilirsiniz.
                </small>
            </div>

            <hr />

            @if (Model.ProductMedias.Any())
            {
                <div class="row g-3">
                    @foreach (var media in Model.ProductMedias)
                    {
                        <div class="col-md-3">
                            <div class="border rounded p-2 text-center">

                                @if (media.MediaType == "Image")
                                {
                                    <img src="@media.FilePath"
                                         class="img-fluid mb-2"
                                         style="max-height:150px; object-fit:contain;" />
                                }
                                else
                                {
                                    <video class="w-100 mb-2" controls>
                                        <source src="@media.FilePath" type="video/mp4" />
                                    </video>
                                }

                                @if (media.IsCover)
                                {
                                    <span class="badge bg-success">Kapak</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@media.MediaType</span>
                                }

                                <div class="mt-2">
                                    @if (!media.IsCover)
                                    {
                                        <button type="submit"
                                                formaction="?handler=SetCover&mediaId=@media.ProductMediaId&productId=@Model.Product.ProductId"
                                                class="btn btn-sm btn-outline-primary w-100">
                                            Kapak Yap
                                        </button>
                                    }

                                    <button type="submit"
                                            formaction="?handler=DeleteMedia&mediaId=@media.ProductMediaId&productId=@Model.Product.ProductId"
                                            class="btn btn-sm btn-outline-danger w-100 mt-1"
                                            onclick="return confirm('Silinsin mi?');">
                                        Sil
                                    </button>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-muted">
                    Bu ürüne ait medya bulunmamaktadır.
                </div>
            }
        </div>
    </div>

    <br />

    <div class="text-end">
        <button type="submit" class="btn btn-success">
            Kaydet
        </button>
        <a asp-page="Index" class="btn btn-secondary">
            Geri Dön
        </a>
    </div>

</form>
