@page
@model TeknoForce.Pages.Reviews.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Yorumlar";
}
<div class="admin-card">
<h3>Yorumlar</h3>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Ürün</th>
            <th>İsim</th>
            <th>Email</th>
            <th>Yorum</th>
            <th>Durum</th>
            <th>Tarih</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var comment in Model.Comments)
        {
            <tr>
                <td>@comment.Product?.Name</td>
                <td>@comment.Name</td>
                <td>@comment.Email</td>
                <td>@comment.Content</td>
                <td>
                    @(comment.IsApproved ? "Onaylı" : "Bekliyor")
                </td>
                <td>@comment.CreatedDate.ToShortDateString()</td>
                <td>
                    @if (!comment.IsApproved)
                    {
                        <form method="post" asp-page-handler="Approve" style="display:inline;">
                            <input type="hidden" name="id" value="@comment.CommentId" />
                            <button type="submit" class="btn btn-sm btn-success">
                                Onayla
                            </button>
                        </form>
                    }

                    <form method="post" asp-page-handler="Delete" style="display:inline;">
                        <input type="hidden" name="id" value="@comment.CommentId" />
                        <button type="submit"
                                class="btn btn-sm btn-danger"
                                onclick="return confirm('Silmek istiyor musunuz?');">
                            Sil
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>