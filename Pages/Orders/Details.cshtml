@*Orders klasöründeki details.cshtml*@
@page "{id:int}"
@model TeknoForce.Pages.Admin.Orders.DetailsModel
@{
    ViewData["Title"] = "Sipariş Detayı";
    Layout = "_AdminLayout";
}
<div class="admin-card">
<h3>Sipariş Detayı</h3>
    <div class="admin-detail-card">

        <div class="admin-detail-title">
            Müşteri Bilgileri
        </div>

        <div class="row">
            <div class="col-md-4">
                <strong>Ad Soyad</strong><br />
                @Model.Order.FullName
            </div>

            <div class="col-md-4">
                <strong>Telefon</strong><br />
                @Model.Order.Phone
            </div>

            <div class="col-md-4">
                <strong>Email</strong><br />
                @Model.Order.Email
            </div>
        </div>

        <hr style="opacity:.1" />

        <strong>Ödeme Yöntemi:</strong>
        @(Model.Order.PaymentMethod == "BankTransfer"
                ? "Havale / EFT"
                : Model.Order.PaymentMethod)

    </div>
    <div class="admin-detail-card">

        <div class="admin-detail-title">
            Teslimat Adresi
        </div>

        <div class="row">
            <div class="col-md-6">
                <strong>Adres Tipi:</strong>
                @(Model.Order.AddressType == "Work" ? "İş" : "Ev")
            </div>

            @if (Model.Order.AddressType == "Work")
            {
                <div class="col-md-6">
                    <strong>Firma:</strong>
                    @Model.Order.CompanyName
                </div>
            }
        </div>

        <div class="mt-3">
            @Model.Order.City / @Model.Order.District <br />
            @Model.Order.Neighborhood, @Model.Order.Street <br />
            No: @Model.Order.BuildingNo,
            Daire: @Model.Order.ApartmentNo
        </div>

    </div>


</div>
<div class="admin-detail-card">

    <div class="admin-detail-title">
        Sipariş Bilgisi
    </div>

    <div class="row align-items-center">

        <!-- Sipariş No -->
        <div class="col-md-3">
            <small class="text-muted">Sipariş No</small>
            <div class="order-number-highlight">
                #@Model.Order.OrderNumber
            </div>
        </div>

        <!-- Tarih -->
        <div class="col-md-3">
            <small class="text-muted">Tarih</small>
            <div>
                @Model.Order.CreatedDate.ToString("dd.MM.yyyy HH:mm")
            </div>
        </div>

        <!-- Mevcut Durum Badge -->
        <div class="col-md-3">
            <small class="text-muted">Mevcut Durum</small><br />  <br />
            <span id="statusBadge"
                  class="status-badge"
                  style="background:@Model.Order.OrderStatus.ColorCode">
                @Model.Order.OrderStatus.Name
            </span>
        </div>

        <!-- Durum Güncelle -->
        <div class="col-md-3">

            <form id="statusForm"
                  method="post"
                  action="?handler=UpdateStatus"
                  class="d-flex flex-column gap-2">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="orderId"
                       value="@Model.Order.OrderId" />

                <select name="orderStatusId"
                        class="form-select form-select-sm">

                    @foreach (var status in Model.StatusList)
                    {
                        <option value="@status.Value"
                                selected="@(status.Value == Model.Order.OrderStatusId.ToString())">
                            @status.Text
                        </option>
                    }

                </select>

                <button type="submit"
                        class="btn btn-sm btn-warning">
                    Kaydet
                </button>

            </form>

        </div>

    </div>

</div>
<div class="admin-card">
    <div class="card-header">
        Sipariş Ürünleri
    </div>
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Ürün</th>
                    <th>Birim Fiyat</th>
                    <th>Adet</th>
                    <th>Toplam</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderItems)
                {
                    <tr>
                        <td>@item.Product.Name</td>
                        <td>@item.UnitPrice.ToString("N2") ₺</td>
                        <td>@item.Quantity</td>
                        <td>@((item.UnitPrice* item.Quantity).ToString("N2")) ₺</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<a asp-page="Index" class="btn btn-secondary mt-3">
    Geri Dön
</a>

<script>
    document.getElementById("statusForm")
        .addEventListener("submit", function(e) {

        e.preventDefault();

        const form = this;

        fetch(form.action, {
            method: "POST",
            body: new FormData(form)
        })
        .then(res => res.json())
        .then(data => {

            if (data.success) {

                // Badge güncelle
                const badge = document.getElementById("statusBadge");
                badge.innerText = data.statusName;
                badge.style.background = data.colorCode;

                showToast("Sipariş durumu güncellendi ✔");
            }

        });
    });
</script>

<style>
    .admin-detail-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 28px;
        margin-bottom: 25px;
        transition: all .25s ease;
        box-shadow: 0 8px 25px rgba(0,0,0,.05);
    }

        .admin-detail-card:hover {
            background: #fff7f1; /* soft turuncu */
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(255,122,0,.15);
        }

    .admin-detail-title {
        font-weight: 600;
        font-size: 18px;
        margin-bottom: 20px;
        color: #2b2b2b;
        border-left: 4px solid #ff7a00;
        padding-left: 12px;
    }

    select.form-select {
        border-radius: 12px;
        border: 1px solid #eee;
        padding: 8px 12px;
    }

    .order-number-highlight {
        font-size: 20px;
        font-weight: 700;
        color: #ff7a00;
    }

    .status-badge {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        color: white;
        font-weight: 500;
    }

    .btn-warning {
        background: linear-gradient(135deg,#ff7a00,#ff9a2f);
        border: none;
        border-radius: 12px;
        transition: all .2s ease;
    }

        .btn-warning:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(255,122,0,.35);
        }
</style>

<div id="toastBox"></div>

<style>
    #toastBox {
        position: fixed;
        top: 25px;
        right: 25px;
        z-index: 9999;
    }

    .toast-message {
        background: linear-gradient(135deg,#ff7a00,#ff9a2f);
        color: white;
        padding: 14px 20px;
        border-radius: 14px;
        box-shadow: 0 10px 25px rgba(255,122,0,.3);
        margin-bottom: 10px;
        animation: slideIn .4s ease forwards;
        font-weight: 500;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(50px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
</style>

<script>
    function showToast(message) {

        const toast = document.createElement("div");
        toast.className = "toast-message";
        toast.innerText = message;

        document.getElementById("toastBox")
            .appendChild(toast);

        setTimeout(() => {
            toast.remove();
        }, 3000);
    }
</script>