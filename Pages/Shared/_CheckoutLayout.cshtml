@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - TeknoForce</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>

    <!-- Minimal Header -->
    <div class="container py-3 d-flex justify-content-between align-items-center">
        <a asp-page="/Index">
            <img src="~/uploads/brands/teknoforce logo.png"
                 style="height:50px;" />
        </a>

        <span class="fw-bold">Güvenli Sipariş</span>
    </div>

    <hr />

    <div class="container">
        @RenderBody()
    </div>

</body>
</html>