@inject TeknoForce.Data.AppDbContext _context

<section class="section--padding">
    <div class="container">

        <div class="section__heading text-center mb-40">
            <h2>Şubelerimiz</h2>
        </div>

        @{
            var branches = _context.ContactBranches
            .Where(x => x.IsActive)
            .ToList();
        }

        <div class="row align-items-stretch">
            @foreach (var branch in branches)
            {
                <div class="col-lg-6 mb-5 d-flex">
                    <div class="card shadow-sm p-4 w-100 h-100">

                        <h4 class="mb-2">@branch.ContactName</h4>

                        <p class="text-muted">@branch.Address</p>

                        @if (!string.IsNullOrEmpty(branch.MapIframe))
                        {
                            <div class="mb-3">
                                @Html.Raw(branch.MapIframe)
                            </div>
                        }

                        <h6 class="mt-3">Telefon</h6>

                        @{
                            var phones = _context.ContactPhones
                            .Where(p => p.ContactBranchId == branch.ContactBranchId && p.IsActive)
                            .OrderBy(p => p.SortOrder)
                            .ToList();
                        }

                        @foreach (var phone in phones)
                        {
                            <p class="mb-1">
                                <strong>@phone.label:</strong> @phone.PhoneNumber
                            </p>
                        }

                    </div>
                </div>
            }
        </div>


        <div class="mt-4 text-center">

            <h6 class="mb-3 fw-bold">Bizi Takip Edin</h6>

            <div class="d-flex justify-content-center gap-3">

                <a href="https://www.instagram.com/boyamateknolojileri?utm_source=qr&igsh=bm01czRmZnptbm5s"
                   target="_blank"
                   class="social-icon instagram">
                    <i class="bi bi-instagram"></i>
                </a>

                <a href="https://www.tiktok.com/@@xforce_boyamakinalari?_r=1&_t=ZS-94PMoa4gEzd"
                   target="_blank"
                   class="social-icon tiktok">
                    <i class="bi bi-tiktok"></i>
                </a>

                <a href="https://www.facebook.com/share/18TWhrENy5/"
                   target="_blank"
                   class="social-icon facebook">
                    <i class="bi bi-facebook"></i>
                </a>

            </div>

        </div>
    </div>

    <style>
        .social-icon {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 20px;
            transition: 0.3s;
        }

        .instagram {
            background: #E1306C;
        }

        .tiktok {
            background: #000000;
        }

        .facebook {
            background: #1877F2;
        }

        .social-icon:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }



    </style>
</section>