@page
@model TeknoForce.Pages.Admin.Contact.Branches.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Şubeler";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Şubeler</h3>

    <a asp-page="Create" class="btn btn-success">
        + Yeni Şube
    </a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>Şube Adı</th>
            <th>Adres</th>
            <th>Durum</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Branches.Any())
        {
            foreach (var branch in Model.Branches)
            {
                <tr>
                    <td>@branch.ContactBranchId</td>
                    <td>@branch.Title</td>
                    <td style="max-width:400px">
                        @branch.Address
                    </td>
                    <td>
                        @(branch.IsActive ? "Aktif" : "Pasif")
                    </td>
                    <td>
                        <a asp-page="Edit"
                           asp-route-id="@branch.ContactBranchId"
                           class="btn btn-sm btn-primary">
                            Düzenle
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">
                    Henüz şube eklenmedi.
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-page="/Admin/Contact/Index" class="btn btn-secondary mt-3">
    İletişim Ayarlarına Dön
</a>
