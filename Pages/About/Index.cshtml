@page   
@model TeknoForce.Pages.Admin.AboutContents.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Hakkımızda";
}

<h3>Hakkımızda</h3>

<form method="post" class="card">
    <div class="card-body">

        <div class="mb-3">
            <label class="form-label">Başlık</label>
            <input asp-for="About.Title" class="form-control" />
            <span asp-validation-for="About.Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">İçerik</label>
            <textarea asp-for="About.Content"
                      class="form-control"
                      rows="8"></textarea>
            <span asp-validation-for="About.Content" class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="About.IsActive"
                   class="form-check-input"
                   type="checkbox" />
            <label class="form-check-label">
                Yayında
            </label>
        </div>

        <button type="submit" class="btn btn-success">
            Kaydet
        </button>
    </div>
</form>
